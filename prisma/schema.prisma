datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

model Member {
  id         Int      @id @default(autoincrement())
  fullName     String   @map("full_name")
  comment String
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("members")
}